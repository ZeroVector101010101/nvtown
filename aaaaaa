local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()

local Window = WindUI:CreateWindow({
    Title = "Farm Bot",
    Icon = "shovel",
    Author = "AutoFarm",
    Folder = "FarmBot",
    Size = UDim2.fromOffset(400, 200),
    Transparent = true,
    Theme = "Dark",
})

Window:SetToggleKey(Enum.KeyCode.RightShift)
Window:IsResizable(false)

local MainSection = Window:Section({ Title = "Farm", Opened = true })
local FarmTab = MainSection:Tab({ Title = "Farm", Icon = "sprout" })
FarmTab:Select()

FarmTab:Toggle({
    Title = "Auto Farm",
    Description = "Pepper → Carrot → Milk → Tomato → Sell | หยุดกินข้าวทุก 20 วิ",
    Value = false,
    Callback = function(state)
        getgenv().FarmActive = state
        if state then
            print("[Farm] เริ่มฟาร์ม")
            task.spawn(startFarmAll)
        else
            print("[Farm] หยุดฟาร์ม")
        end
    end
})

